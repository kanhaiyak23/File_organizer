{
    "rules": [
        {
            "name": "Large Videos",
            "priority": 100,
            "conditions": {
                "extensions": [
                    "mp4",
                    "mkv",
                    "avi",
                    "mov",
                    "wmv"
                ],
                "minSize": 104857600
            },
            "category": "Videos/Large",
            "enabled": true
        },
        {
            "name": "Large Archives",
            "priority": 100,
            "conditions": {
                "extensions": [
                    "zip",
                    "rar",
                    "7z",
                    "tar",
                    "gz"
                ],
                "minSize": 104857600
            },
            "category": "Archives/Large",
            "enabled": true
        },
        {
            "name": "Screenshots",
            "priority": 90,
            "conditions": {
                "extensions": [
                    "png",
                    "jpg",
                    "jpeg"
                ],
                "namePattern": "^(Screenshot|Screen Shot|Capture)"
            },
            "category": "Images/Screenshots",
            "enabled": true
        },
        {
            "name": "Documents",
            "priority": 50,
            "conditions": {
                "extensions": [
                    "pdf",
                    "doc",
                    "docx",
                    "txt",
                    "rtf",
                    "odt",
                    "pages"
                ]
            },
            "category": "Documents",
            "enabled": true
        },
        {
            "name": "Spreadsheets",
            "priority": 50,
            "conditions": {
                "extensions": [
                    "xls",
                    "xlsx",
                    "csv",
                    "ods",
                    "numbers"
                ]
            },
            "category": "Spreadsheets",
            "enabled": true
        },
        {
            "name": "Presentations",
            "priority": 50,
            "conditions": {
                "extensions": [
                    "ppt",
                    "pptx",
                    "odp",
                    "key"
                ]
            },
            "category": "Presentations",
            "enabled": true
        },
        {
            "name": "Images",
            "priority": 40,
            "conditions": {
                "extensions": [
                    "jpg",
                    "jpeg",
                    "png",
                    "gif",
                    "bmp",
                    "svg",
                    "webp",
                    "ico",
                    "heic",
                    "raw"
                ]
            },
            "category": "Images",
            "enabled": true
        },
        {
            "name": "Videos",
            "priority": 40,
            "conditions": {
                "extensions": [
                    "mp4",
                    "mkv",
                    "avi",
                    "mov",
                    "wmv",
                    "flv",
                    "webm",
                    "m4v"
                ]
            },
            "category": "Videos",
            "enabled": true
        },
        {
            "name": "Audio",
            "priority": 50,
            "conditions": {
                "extensions": [
                    "mp3",
                    "wav",
                    "flac",
                    "aac",
                    "ogg",
                    "m4a",
                    "wma"
                ]
            },
            "category": "Audio",
            "enabled": true
        },
        {
            "name": "Archives",
            "priority": 40,
            "conditions": {
                "extensions": [
                    "zip",
                    "rar",
                    "7z",
                    "tar",
                    "gz",
                    "bz2",
                    "xz"
                ]
            },
            "category": "Archives",
            "enabled": true
        },
        {
            "name": "Code",
            "priority": 50,
            "conditions": {
                "extensions": [
                    "js",
                    "ts",
                    "jsx",
                    "tsx",
                    "py",
                    "java",
                    "c",
                    "cpp",
                    "h",
                    "hpp",
                    "cs",
                    "go",
                    "rs",
                    "rb",
                    "php",
                    "swift",
                    "kt",
                    "scala",
                    "lua"
                ]
            },
            "category": "Code",
            "enabled": true
        },
        {
            "name": "Web Files",
            "priority": 45,
            "conditions": {
                "extensions": [
                    "html",
                    "css",
                    "scss",
                    "sass",
                    "less"
                ]
            },
            "category": "Web",
            "enabled": true
        },
        {
            "name": "Data Files",
            "priority": 45,
            "conditions": {
                "extensions": [
                    "json",
                    "xml",
                    "yaml",
                    "yml",
                    "toml",
                    "sql",
                    "db",
                    "sqlite"
                ]
            },
            "category": "Data",
            "enabled": true
        },
        {
            "name": "Executables",
            "priority": 60,
            "conditions": {
                "extensions": [
                    "exe",
                    "msi",
                    "dmg",
                    "pkg",
                    "app",
                    "deb",
                    "rpm",
                    "appimage"
                ]
            },
            "category": "Executables",
            "enabled": true
        },
        {
            "name": "Disk Images",
            "priority": 55,
            "conditions": {
                "extensions": [
                    "iso",
                    "img",
                    "vmdk",
                    "vdi"
                ]
            },
            "category": "DiskImages",
            "enabled": true
        },
        {
            "name": "Fonts",
            "priority": 50,
            "conditions": {
                "extensions": [
                    "ttf",
                    "otf",
                    "woff",
                    "woff2",
                    "eot"
                ]
            },
            "category": "Fonts",
            "enabled": true
        },
        {
            "name": "E-books",
            "priority": 55,
            "conditions": {
                "extensions": [
                    "epub",
                    "mobi",
                    "azw",
                    "azw3"
                ]
            },
            "category": "Ebooks",
            "enabled": true
        },
        {
            "name": "Design Files",
            "priority": 55,
            "conditions": {
                "extensions": [
                    "psd",
                    "ai",
                    "sketch",
                    "fig",
                    "xd"
                ]
            },
            "category": "Design",
            "enabled": true
        },
        {
            "name": "Other",
            "priority": 0,
            "conditions": {},
            "category": "Other",
            "enabled": true
        }
    ]
}